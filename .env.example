# Copy to .env and fill in. Never commit .env — this repo will go public.
# All secrets live only on the server; the frontend never sees them.

# Anthropic key — Claude vision (trait extraction, view classification, checking)
ANTHROPIC_API_KEY=

# --- Auth (GitHub OAuth) ---
# Create a GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL:              http://localhost:3000
#   Authorization callback URL: http://localhost:3000/auth/callback
# then paste the Client ID + Secret here.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Secret used to sign session cookies. Generate one, e.g. `openssl rand -hex 32`.
SESSION_SECRET=

# fal.ai key — only needed if you re-enable in-app generation (currently dormant)
FAL_KEY=

# Optional: server port (default 3000)
PORT=3000
